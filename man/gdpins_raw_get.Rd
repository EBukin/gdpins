\section{Name resolution}{

\code{\link[=gdpins_raw_path]{gdpins_raw_path()}}, \code{\link[=gdpins_raw_get]{gdpins_raw_get()}} and \code{\link[=gdpins_pin_read]{gdpins_pin_read()}} resolve the
